{
  "name": "weather-realteeth",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "concurrently -n app,messages,steiger -c blue,green,yellow \"pnpm dev:app\" \"pnpm dev:messages\" \"pnpm dev:steiger\"",
    "dev:app": "next dev",
    "dev:messages": "tsx scripts/build-messages.ts --watch",
    "dev:steiger": "steiger . --watch",
    "build": "pnpm build:messages && pnpm lint:steiger && next build",
    "build:messages": "tsx scripts/build-messages.ts",
    "start": "next start",
    "lint": "pnpm lint:eslint && pnpm lint:steiger",
    "lint:eslint": "eslint",
    "lint:steiger": "steiger .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-use": "^17.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "steiger": "^0.5.11",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "yaml": "^2.8.3"
  }
}
